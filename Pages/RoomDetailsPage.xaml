<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="HomeGlass.Pages.RoomDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock x:Name="RoomNameTextBlock" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Room details" />
        </StackPanel>

        <ItemsControl x:Name="StatusItemsControl" Grid.Row="1">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,8,8"
                        Padding="10,6"
                        Background="{Binding Background}"
                        CornerRadius="8"
                        ToolTipService.ToolTip="{Binding ToolTip}">
                        <TextBlock FontWeight="SemiBold" Foreground="{Binding Foreground}" Text="{Binding Text}" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>
</Page>
