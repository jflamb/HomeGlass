<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="HomeGlass.Pages.RoomDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock x:Name="RoomNameTextBlock" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Room details" />
        </StackPanel>

        <ItemsControl x:Name="StatusItemsControl" Grid.Row="1">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,8,8"
                        Padding="10,6"
                        Background="{Binding Background}"
                        CornerRadius="8"
                        ToolTipService.ToolTip="{Binding ToolTip}">
                        <TextBlock FontWeight="SemiBold" Foreground="{Binding Foreground}" Text="{Binding Text}" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ListView
                x:Name="DeviceGroupsListView"
                IsItemClickEnabled="False"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="10" Margin="0,0,0,20">
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding Name}" />
                                <TextBlock Text="{Binding Summary}" />
                            </StackPanel>

                            <GridView
                                ItemClick="DeviceGridView_ItemClick"
                                ItemsSource="{Binding Devices}"
                                IsItemClickEnabled="True"
                                SelectionMode="None">
                                <GridView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="260"
                                            MinHeight="142"
                                            Padding="16"
                                            Background="{Binding CardBackground}"
                                            BorderBrush="{Binding CardBorderBrush}"
                                            BorderThickness="{Binding CardBorderThickness}"
                                            CornerRadius="8"
                                            Opacity="{Binding CardOpacity}">
                                            <StackPanel Spacing="10">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon
                                                        Width="20"
                                                        Height="24"
                                                        Margin="0,3,0,0"
                                                        FontSize="18"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Top"
                                                        Glyph="{Binding IconGlyph}" />
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                                        <ProgressRing
                                                            Width="24"
                                                            Height="24"
                                                            IsActive="{Binding IsBusy}"
                                                            Visibility="{Binding BusyVisibility}" />
                                                        <Button
                                                            Width="32"
                                                            Height="32"
                                                            Padding="0"
                                                            Click="ToggleDeviceButton_Click"
                                                            CommandParameter="{Binding}"
                                                            IsEnabled="{Binding IsEnabled}"
                                                            ToolTipService.ToolTip="{Binding ToggleToolTip}"
                                                            Visibility="{Binding QuickActionVisibility}">
                                                            <FontIcon FontSize="14" Glyph="{Binding ActionGlyph}" />
                                                        </Button>
                                                        <Button
                                                            Width="32"
                                                            Height="32"
                                                            Padding="0"
                                                            IsEnabled="{Binding IsEnabled}"
                                                            ToolTipService.ToolTip="More controls"
                                                            Visibility="{Binding DetailControlsVisibility}">
                                                            <FontIcon FontSize="14" Glyph="&#xE712;" />
                                                            <Button.Flyout>
                                                                <Flyout Placement="Right">
                                                                    <StackPanel Width="300" Spacing="14">
                                                                        <StackPanel Spacing="2">
                                                                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                                                            <TextBlock Text="{Binding ControlSummary}" TextWrapping="Wrap" />
                                                                        </StackPanel>

                                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                                            <Button
                                                                                Click="SetDevicePowerButton_Click"
                                                                                CommandParameter="{Binding}"
                                                                                IsEnabled="{Binding IsEnabled}"
                                                                                Tag="turn_on">
                                                                                <TextBlock Text="On" />
                                                                            </Button>
                                                                            <Button
                                                                                Click="SetDevicePowerButton_Click"
                                                                                CommandParameter="{Binding}"
                                                                                IsEnabled="{Binding IsEnabled}"
                                                                                Tag="turn_off">
                                                                                <TextBlock Text="Off" />
                                                                            </Button>
                                                                        </StackPanel>

                                                                        <StackPanel Spacing="6" Visibility="{Binding BrightnessVisibility}">
                                                                            <TextBlock Text="{Binding BrightnessLabel}" />
                                                                            <Slider
                                                                                Maximum="100"
                                                                                Minimum="1"
                                                                                StepFrequency="1"
                                                                                Value="{Binding BrightnessPercent, Mode=TwoWay}" />
                                                                        </StackPanel>

                                                                        <StackPanel Spacing="6" Visibility="{Binding ColorTemperatureVisibility}">
                                                                            <TextBlock Text="{Binding ColorTemperatureLabel}" />
                                                                            <Slider
                                                                                Maximum="{Binding MaxColorTemperatureKelvin}"
                                                                                Minimum="{Binding MinColorTemperatureKelvin}"
                                                                                StepFrequency="50"
                                                                                Value="{Binding ColorTemperatureKelvin, Mode=TwoWay}" />
                                                                        </StackPanel>

                                                                        <StackPanel Spacing="6" Visibility="{Binding ColorVisibility}">
                                                                            <TextBlock Text="Color" />
                                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                                <Button
                                                                                    Width="32"
                                                                                    Height="32"
                                                                                    Padding="0"
                                                                                    Background="#FFFFA05A"
                                                                                    BorderThickness="1"
                                                                                    Click="SetLightColorButton_Click"
                                                                                    CommandParameter="{Binding}"
                                                                                    IsEnabled="{Binding IsEnabled}"
                                                                                    Tag="255,160,90" />
                                                                                <Button
                                                                                    Width="32"
                                                                                    Height="32"
                                                                                    Padding="0"
                                                                                    Background="#FFFFD666"
                                                                                    BorderThickness="1"
                                                                                    Click="SetLightColorButton_Click"
                                                                                    CommandParameter="{Binding}"
                                                                                    IsEnabled="{Binding IsEnabled}"
                                                                                    Tag="255,214,102" />
                                                                                <Button
                                                                                    Width="32"
                                                                                    Height="32"
                                                                                    Padding="0"
                                                                                    Background="#FF5EEAD4"
                                                                                    BorderThickness="1"
                                                                                    Click="SetLightColorButton_Click"
                                                                                    CommandParameter="{Binding}"
                                                                                    IsEnabled="{Binding IsEnabled}"
                                                                                    Tag="94,234,212" />
                                                                                <Button
                                                                                    Width="32"
                                                                                    Height="32"
                                                                                    Padding="0"
                                                                                    Background="#FF60A5FA"
                                                                                    BorderThickness="1"
                                                                                    Click="SetLightColorButton_Click"
                                                                                    CommandParameter="{Binding}"
                                                                                    IsEnabled="{Binding IsEnabled}"
                                                                                    Tag="96,165,250" />
                                                                                <Button
                                                                                    Width="32"
                                                                                    Height="32"
                                                                                    Padding="0"
                                                                                    Background="#FFA78BFA"
                                                                                    BorderThickness="1"
                                                                                    Click="SetLightColorButton_Click"
                                                                                    CommandParameter="{Binding}"
                                                                                    IsEnabled="{Binding IsEnabled}"
                                                                                    Tag="167,139,250" />
                                                                            </StackPanel>
                                                                        </StackPanel>

                                                                        <Button
                                                                            Click="ApplyLightControlsButton_Click"
                                                                            CommandParameter="{Binding}"
                                                                            IsEnabled="{Binding IsEnabled}"
                                                                            Visibility="{Binding LightControlsVisibility}">
                                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                                <ProgressRing
                                                                                    Width="16"
                                                                                    Height="16"
                                                                                    IsActive="{Binding IsBusy}"
                                                                                    Visibility="{Binding BusyVisibility}" />
                                                                                <TextBlock Text="Apply" />
                                                                            </StackPanel>
                                                                        </Button>
                                                                    </StackPanel>
                                                                </Flyout>
                                                            </Button.Flyout>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding StatusChips}">
                                                    <ItemsControl.HorizontalAlignment>Left</ItemsControl.HorizontalAlignment>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border
                                                                Margin="0,0,6,6"
                                                                Padding="8,4"
                                                                Background="{Binding Background}"
                                                                CornerRadius="8"
                                                                ToolTipService.ToolTip="{Binding ToolTip}">
                                                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding Foreground}" Text="{Binding Text}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>
