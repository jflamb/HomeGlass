<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="HomeGlass.Pages.RoomsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Rooms" />
            <TextBlock x:Name="RoomsSummaryText" TextWrapping="Wrap" />
        </StackPanel>

        <InfoBar
            x:Name="RoomsInfoBar"
            Grid.Row="1"
            IsOpen="False"
            IsClosable="True" />

        <GridView
            x:Name="RoomsGridView"
            Grid.Row="2"
            IsItemClickEnabled="False"
            SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Width="220"
                        MinHeight="128"
                        Padding="18"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="8">
                            <FontIcon HorizontalAlignment="Left" Glyph="{Binding IconGlyph}" />
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
