<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="HomeGlass.Pages.RoomsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Rooms" />
            <TextBlock x:Name="RoomsSummaryText" TextWrapping="Wrap" />
        </StackPanel>

        <InfoBar
            x:Name="RoomsInfoBar"
            Grid.Row="1"
            IsOpen="False"
            IsClosable="True" />

        <ScrollViewer
            Grid.Row="2"
            VerticalScrollBarVisibility="Auto">
            <ListView
                x:Name="RoomGroupsListView"
                IsItemClickEnabled="False"
                SelectionMode="None">
                <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Spacing="10" Margin="0,0,0,20">
                        <StackPanel Spacing="2">
                            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding Name}" />
                            <TextBlock Text="{Binding Summary}" />
                        </StackPanel>

                        <GridView
                            ItemClick="RoomGridView_ItemClick"
                            IsItemClickEnabled="True"
                            ItemsSource="{Binding Rooms}"
                            SelectionMode="None">
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="260"
                                        MinHeight="164"
                                        Padding="18"
                                        Background="{Binding CardBackground}"
                                        BorderBrush="{Binding CardBorderBrush}"
                                        BorderThickness="{Binding CardBorderThickness}"
                                        CornerRadius="8">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon
                                                    Width="20"
                                                    Height="24"
                                                    Margin="0,3,0,0"
                                                    FontSize="18"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Glyph="{Binding IconGlyph}" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding StatusChips}">
                                                <ItemsControl.HorizontalAlignment>Left</ItemsControl.HorizontalAlignment>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border
                                                            Margin="0,0,6,6"
                                                            Padding="8,4"
                                                            Background="{Binding Background}"
                                                            CornerRadius="8"
                                                            ToolTipService.ToolTip="{Binding ToolTip}">
                                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{Binding Foreground}" Text="{Binding Text}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>

                                            <StackPanel
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                Visibility="{Binding HasQuickActions}">
                                                <Button
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    Click="QuickActionButton_Click"
                                                    CommandParameter="{Binding LightAction}"
                                                    IsEnabled="{Binding LightAction.IsEnabled}"
                                                    ToolTipService.ToolTip="{Binding LightAction.ToolTip}"
                                                    Visibility="{Binding LightAction.Visibility}">
                                                    <Grid>
                                                        <FontIcon FontSize="14" Glyph="&#xE706;" Visibility="{Binding LightAction.IconVisibility}" />
                                                        <ProgressRing Width="16" Height="16" IsActive="{Binding LightAction.IsBusy}" Visibility="{Binding LightAction.BusyVisibility}" />
                                                    </Grid>
                                                </Button>
                                                <Button
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    Click="QuickActionButton_Click"
                                                    CommandParameter="{Binding FanAction}"
                                                    IsEnabled="{Binding FanAction.IsEnabled}"
                                                    ToolTipService.ToolTip="{Binding FanAction.ToolTip}"
                                                    Visibility="{Binding FanAction.Visibility}">
                                                    <Grid>
                                                        <PathIcon
                                                            Width="16"
                                                            Height="16"
                                                            Data="M8,2 C9.4,4.1 9.1,5.9 8.2,7.1 C10.2,6.7 12.1,7.2 14,8.6 C11.6,9.8 9.9,9.6 8.7,8.7 C9.1,10.7 8.6,12.5 7.2,14 C6.1,11.7 6.3,10 7.2,8.8 C5.2,9.2 3.3,8.7 2,7.4 C4.2,6.2 5.9,6.4 7.1,7.3 C6.7,5.3 7.1,3.5 8,2 Z M8,7.25 A0.75,0.75 0,1,0 8,8.75 A0.75,0.75 0,0,0 8,7.25 Z"
                                                            Visibility="{Binding FanAction.IconVisibility}" />
                                                        <ProgressRing Width="16" Height="16" IsActive="{Binding FanAction.IsBusy}" Visibility="{Binding FanAction.BusyVisibility}" />
                                                    </Grid>
                                                </Button>
                                                <Button
                                                    Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    Click="QuickActionButton_Click"
                                                    CommandParameter="{Binding LockAction}"
                                                    IsEnabled="{Binding LockAction.IsEnabled}"
                                                    ToolTipService.ToolTip="{Binding LockAction.ToolTip}"
                                                    Visibility="{Binding LockAction.Visibility}">
                                                    <Grid>
                                                        <FontIcon FontSize="14" Glyph="&#xE72E;" Visibility="{Binding LockAction.IconVisibility}" />
                                                        <ProgressRing Width="16" Height="16" IsActive="{Binding LockAction.IsBusy}" Visibility="{Binding LockAction.BusyVisibility}" />
                                                    </Grid>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>
                </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>
