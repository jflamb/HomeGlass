<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="HomeGlass.Pages.ScenesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Scenes" />

        <StackPanel Grid.Row="1" Spacing="12">
            <Button HorizontalAlignment="Stretch" Content="Good Morning" />
            <Button HorizontalAlignment="Stretch" Content="Movie Night" />
            <Button HorizontalAlignment="Stretch" Content="Away" />
            <Button HorizontalAlignment="Stretch" Content="All Off" />
        </StackPanel>
    </Grid>
</Page>
